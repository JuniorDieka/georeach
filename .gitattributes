# Set default behavior to automatically normalize line endings
* text=auto

# Python files should always use LF
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sql text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.parquet binary
*.tif binary
*.tiff binary
